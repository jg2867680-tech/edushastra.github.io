<!-- ══════════════════════════════
     SECTION: EXAM STRUCTURE
══════════════════════════════ -->
<section id="syllabus" class="py-24 px-6 bg-ink-800/20">
  <div class="max-w-7xl mx-auto">

    <div class="reveal mb-16 flex flex-col md:flex-row md:items-end md:justify-between gap-6">
      <div>
        <p class="text-brand-400 text-xs font-semibold tracking-widest uppercase mb-3">What You're Preparing For</p>
        <h2 class="font-display text-4xl md:text-5xl font-800 text-white leading-tight">
          CUET Exam<br/><span class="text-brand-500">Structure</span>
        </h2>
      </div>
      <p class="text-ink-200 max-w-sm text-sm leading-relaxed">All questions benchmarked at Class XII level. NCERT syllabus only for domain subjects.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
      {[
        {
          label: "Section IA",
          title: "13 Languages",
          detail: "Reading Comprehension — Factual, Literary, Narrative passages + Literary Aptitude & Vocabulary",
          questions: "40 of 50",
          time: "45 min",
          color: "blue"
        },
        {
          label: "Section IB - Optional ",
          title: "20 Languages",
          detail: "Foreign & regional languages beyond Section IA. Same reading comprehension format.",
          questions: "40 of 50",
          time: "45 min",
          color: "purple"
        },
        {
          label: "Section II",
          title: "27 Domain Subjects",
          detail: "MCQs strictly mapped to NCERT Class XII syllabus. Commerce, Science, Humanities, Arts.",
          questions: "40 of 50",
          time: "45 min",
          color: "teal"
        },
        {
          label: "Section III",
          title: "General Test",
          detail: "GK, Current Affairs, Mental Ability, Numerical Ability, Quantitative Reasoning, Logical & Analytical Reasoning",
          questions: "60 of 75",
          time: "60 min",
          color: "orange"
        },
      ].map(s => (
        <div class={`reveal tier-card glass rounded-3xl p-7 ${s.color === 'orange' ? 'border-brand-500/30' : ''}`}>
          <span class="batch-tag mb-4 inline-block" style={`background: rgba(${s.color==='blue'?'59,130,246':s.color==='purple'?'168,85,247':s.color==='teal'?'20,184,166':'249,115,22'},0.12); color: ${s.color==='blue'?'#93c5fd':s.color==='purple'?'#d8b4fe':s.color==='teal'?'#5eead4':'#fb923c'}; border: 1px solid rgba(${s.color==='blue'?'59,130,246':s.color==='purple'?'168,85,247':s.color==='teal'?'20,184,166':'249,115,22'},0.3);`}>
            {s.label}
          </span>
          <h3 class="font-display text-xl font-700 text-white mb-3">{s.title}</h3>
          <p class="text-ink-200 text-xs leading-relaxed mb-5">{s.detail}</p>
          <div class="flex gap-4 text-xs">
            <div class="glass rounded-lg px-3 py-2 text-center">
              <p class="font-display font-700 text-white">{s.questions}</p>
              <p class="text-ink-400 mt-0.5">Questions</p>
            </div>
            <div class="glass rounded-lg px-3 py-2 text-center">
              <p class="font-display font-700 text-white">{s.time}</p>
              <p class="text-ink-400 mt-0.5">Duration</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Domain subjects quick list -->
    <div class="reveal glass rounded-3xl p-8">
      <h3 class="font-display text-xl font-700 text-white mb-6">Section II — All 27 Domain Subjects</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-2 text-sm text-ink-200">
        {[
          "Accountancy / Book Keeping","Biology / Biotech / Biochemistry","Business Studies","Chemistry",
          "Computer Science / Informatics Practices","Economics / Business Economics","Engineering Graphics",
          "Entrepreneurship","Geography / Geology","History","Home Science",
          "Knowledge Tradition & Practices of India","Legal Studies","Environmental Science",
          "Mathematics","Physical Education / NCC / Yoga","Physics","Political Science","Psychology",
          "Sociology","Teaching Aptitude","Agriculture","Mass Media / Mass Communication",
          "Anthropology","Fine Arts / Visual Arts","Performing Arts","Sanskrit"
        ].map(sub => (
          <div class="flex items-center gap-2 py-1.5 border-b border-white/05">
            <span class="w-1.5 h-1.5 bg-brand-500 rounded-full flex-shrink-0"></span>
            {sub}
          </div>
        ))}
      </div>
      <a href="https://www.edushastra.com/cuet-syllabus" target="_blank" rel="noopener" class="inline-block mt-6 text-brand-400 hover:text-brand-300 text-sm font-semibold transition-colors">
        View full syllabus for each subject →
      </a>
    </div>

  </div>
</section>


<!-- ══════════════════════════════
