        <div class="space-y-3 text-sm">
          {[
            ["Exam Dates",    "May 11 – May 31, 2026 (Tentative)"],
            ["Mode",          "Computer Based Test (CBT)"],
            ["Eligibility",   "Class 12 passed / appearing"],
            ["Sections",      "IA: 13 Languages · IB: 20 Languages · II: 27 Domains · III: General Test"],
            ["Marking",       "+5 correct · –1 wrong (MCQs)"],
            ["Max Subjects",  "10 subjects total across all sections"],
