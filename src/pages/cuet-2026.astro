      <p class="text-ink-200 text-sm">Large-format live courses with 24×7 doubt support. 50% off currently.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

      <!-- Free Hybrid -->
      <div class="tier-card glass rounded-3xl overflow-hidden">
        <div class="h-1 bg-gradient-to-r from-brand-500 to-brand-400"></div>
        <div class="p-7">
          <div class="flex justify-between items-start mb-4">
            <div>
              <span class="batch-tag badge-hybrid mb-2 inline-block">Hybrid</span>
              <h4 class="font-display text-lg font-700 text-white">Free Live Hybrid Course</h4>
            </div>
            <div class="text-right">
              <p class="font-display text-2xl font-800 text-brand-400">Free</p>
              <p class="text-ink-400 text-xs line-through">₹15,999</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-ink-200 mb-6">
            <li class="flex gap-2"><span class="text-brand-400">✓</span> 500+ Hours Course Cycle</li>
            <li class="flex gap-2"><span class="text-brand-400">✓</span> Audio, Video & Chat Interaction</li>
